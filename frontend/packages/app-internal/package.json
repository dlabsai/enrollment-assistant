{
    "name": "@va/app-internal",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev-local": "vite --mode internal-local",
        "build-local": "pnpm -w exec tsgo -b packages/app-internal && vite build --mode internal-local",
        "build-stage": "pnpm -w exec tsgo -b packages/app-internal && vite build --mode internal-stage",
        "build-prod": "pnpm -w exec tsgo -b packages/app-internal && vite build --mode internal-prod",
        "type-check": "pnpm -w exec tsgo -b --noEmit packages/app-internal",
        "lint": "eslint src vite.config.ts --fix --cache --cache-strategy content --cache-location ../../node_modules/.cache/eslint/app-internal",
        "test:traces": "node --experimental-strip-types --test tests/trace-utils.test.ts",
        "preview-local": "vite preview --mode internal-local",
        "preview-stage": "vite preview --mode internal-stage",
        "preview-prod": "vite preview --mode internal-prod"
    },
    "dependencies": {
        "@codemirror/language": "^6.12.3",
        "@codemirror/legacy-modes": "^6.5.2",
        "@codemirror/view": "^6.40.0",
        "@microsoft/teams-js": "^2.51.0",
        "@tabler/icons-react": "^3.40.0",
        "@tanstack/react-router": "^1.168.5",
        "@tanstack/react-table": "^8.21.3",
        "@uiw/codemirror-theme-github": "^4.25.9",
        "@uiw/react-codemirror": "^4.25.9",
        "@va/shared": "workspace:*",
        "codemirror": "^6.0.2",
        "lucide-react": "^1.7.0",
        "nanoid": "^5.1.7",
        "react": "^19.2.4",
        "react-base16-styling": "^0.10.0",
        "react-codemirror-merge": "^4.25.9",
        "react-dom": "^19.2.4",
        "react-error-boundary": "^6.1.1",
        "react-hook-form": "^7.72.0",
        "react-json-tree": "^0.20.0",
        "recharts": "^3.8.1",
        "sonner": "^2.0.7",
        "zustand": "^5.0.12"
    },
    "devDependencies": {
        "vite": "^8.0.3"
    }
}
