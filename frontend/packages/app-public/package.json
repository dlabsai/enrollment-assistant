{
    "name": "@va/app-public",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev-local": "vite --mode public-local",
        "build-local": "pnpm -w exec tsgo -b packages/app-public && vite build --mode public-local",
        "build-stage": "pnpm -w exec tsgo -b packages/app-public && vite build --mode public-stage",
        "build-prod": "pnpm -w exec tsgo -b packages/app-public && vite build --mode public-prod",
        "type-check": "pnpm -w exec tsgo -b --noEmit packages/app-public",
        "lint": "eslint src vite.config.ts --fix --cache --cache-strategy content --cache-location ../../node_modules/.cache/eslint/app-public",
        "preview-local": "vite preview --mode public-local",
        "preview-stage": "vite preview --mode public-stage",
        "preview-prod": "vite preview --mode public-prod"
    },
    "dependencies": {
        "@va/shared": "workspace:*",
        "lucide-react": "^1.7.0",
        "nanoid": "^5.1.7",
        "react": "^19.2.4",
        "react-dom": "^19.2.4"
    },
    "devDependencies": {
        "vite": "^8.0.3"
    }
}
