# LLM provider credentials
# RAG embeddings currently use Azure OpenAI resource 1.
AZURE_API_KEY_1=
AZURE_API_BASE_1=https://your-azure-openai-resource.openai.azure.com/
AZURE_API_VERSION_1=latest

# Optional second Azure OpenAI resource for selected deployments.
AZURE_API_KEY_2=
AZURE_API_BASE_2=
AZURE_API_VERSION_2=latest
AZURE_MODEL_RESOURCE_MAP=

# Optional chat/eval providers.
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Enabled chat models shown in the UI. Replace deployment/model names for your environment.
MODELS=azure/your-chat-deployment
CHATBOT_MODEL=azure/your-chat-deployment
INVESTIGATION_MODEL=azure/your-chat-deployment
GUARDRAIL_MODEL=azure/your-chat-deployment
EVALUATION_MODEL=azure/your-chat-deployment
SUMMARIZER_MODEL=azure/your-chat-deployment
GROUNDING_MODEL=azure/your-chat-deployment

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=postgres

# Pytest external DB on the same local Postgres service (second logical DB created by docker compose).
# Must end with _test and differ from POSTGRES_DB.
PYTEST_POSTGRES_SERVER=localhost
PYTEST_POSTGRES_PORT=5432
PYTEST_POSTGRES_USER=postgres
PYTEST_POSTGRES_PASSWORD=
PYTEST_POSTGRES_DB=postgres_test

BACKEND_CORS_ORIGINS=http://localhost:8000,http://localhost:9000,http://localhost:5173,http://localhost:5174

DOCKER_IMAGE_BACKEND=backend
DOCKER_IMAGE_FRONTEND=frontend
BACKEND_HOST=localhost
FRONTEND_HOST=http://localhost:5174
ENVIRONMENT=local

# Frontend dev servers
VITE_API_URL=http://localhost:8000/api

# Required for auth/session signing. Set a long random value before enabling login.
JWT_SECRET_KEY=

# Registration tokens. Set these to enable registration for each role.
USER_REGISTRATION_TOKEN=
ADMIN_REGISTRATION_TOKEN=
DEV_REGISTRATION_TOKEN=

# Optional Microsoft Teams SSO. Keep disabled for normal local development.
TEAMS_SSO_ENABLED=false
TEAMS_SSO_TENANT_ID=
TEAMS_SSO_CLIENT_ID=
TEAMS_SSO_RESOURCE=
TEAMS_SSO_ALLOWED_AUDIENCES=

# Scheduler toggle. Accepted true values include true/t/yes/y/on/1; accepted false
# values include false/f/no/n/off/0. Docker Compose and Azure deployment use a
# separate scheduler process while forcing web workers to SCHEDULER=false.
SCHEDULER=false

# Optional Langfuse OTLP destination.
LANGFUSE_OTEL_ENABLED=false
LANGFUSE_OTEL_ENDPOINT=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_INGESTION_VERSION=4
# local|dev|prod
LANGFUSE_ENVIRONMENT=
